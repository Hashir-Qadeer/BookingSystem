@model BookingSystem.ViewModels.ProviderDashboardViewModel

@{
    ViewData["Title"] = "Provider Dashboard";
}

<section class="py-4 bg-primary text-white">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h2 class="fw-bold mb-2">Welcome back, @Model.Provider.FirstName!</h2>
                <p class="mb-0">Manage your appointments and schedule</p>
            </div>
            <div class="col-md-4 text-md-end mt-3 mt-md-0">
                <button class="btn btn-light" id="toggleAvailability">
                    <i class="bi bi-power"></i>
                    @(Model.Provider.IsAvailable ? "Set Unavailable" : "Set Available")
                </button>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <!-- Stats Cards -->
        <div class="row g-4 mb-5">
            <div class="col-lg-3 col-md-6">
                <div class="stat-card-dashboard card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <p class="text-muted mb-1">Today's Appointments</p>
                                <h3 class="fw-bold mb-0">@Model.TodayAppointmentsCount</h3>
                            </div>
                            <div class="stat-icon bg-primary-subtle">
                                <i class="bi bi-calendar-day text-primary"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-6">
                <div class="stat-card-dashboard card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <p class="text-muted mb-1">This Week</p>
                                <h3 class="fw-bold mb-0">@Model.WeekAppointmentsCount</h3>
                            </div>
                            <div class="stat-icon bg-warning-subtle">
                                <i class="bi bi-calendar-week text-warning"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-6">
                <div class="stat-card-dashboard card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <p class="text-muted mb-1">This Month</p>
                                <h3 class="fw-bold mb-0">@Model.MonthAppointmentsCount</h3>
                            </div>
                            <div class="stat-icon bg-success-subtle">
                                <i class="bi bi-calendar-month text-success"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-6">
                <div class="stat-card-dashboard card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <p class="text-muted mb-1">Month Revenue</p>
                                <h3 class="fw-bold mb-0">$@Model.MonthRevenue.ToString("0.00")</h3>
                            </div>
                            <div class="stat-icon bg-info-subtle">
                                <i class="bi bi-currency-dollar text-info"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <!-- Today's Appointments -->
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h5 class="fw-bold mb-0">
                                <i class="bi bi-calendar-day text-primary"></i>
                                Today's Schedule
                            </h5>
                            <span class="badge bg-primary">@DateTime.Today.ToString("MMM dd, yyyy")</span>
                        </div>

                        @if (Model.TodayAppointments.Any())
                        {
                            foreach (var appointment in Model.TodayAppointments)
                            {
                                <div class="appointment-card mb-3 p-3 border rounded">
                                    <div class="row align-items-center">
                                        <div class="col-md-8">
                                            <div class="d-flex gap-3">
                                                <div class="time-badge">
                                                    <i class="bi bi-clock"></i>
                                                    <span class="fw-bold">@String.Format("{0:hh\\:mm tt}", DateTime.Today.Add(appointment.StartTime))</span>
                                                </div>
                                                <div>
                                                    <span class="badge bg-success mb-1">@appointment.Status</span>
                                                    <h6 class="fw-bold mb-1">@appointment.Service.Name</h6>
                                                    <p class="text-muted small mb-0">
                                                        <i class="bi bi-person"></i> Customer Name
                                                        <span class="mx-2">•</span>
                                                        <i class="bi bi-currency-dollar"></i> $@appointment.Service.Price
                                                    </p>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-4 text-md-end mt-3 mt-md-0">
                                            <div class="btn-group-sm">
                                                <button class="btn btn-sm btn-outline-success" onclick="completeAppointment(@appointment.AppointmentId)">
                                                    <i class="bi bi-check-lg"></i> Complete
                                                </button>
                                                <button class="btn btn-sm btn-outline-danger" onclick="cancelAppointment(@appointment.AppointmentId)">
                                                    <i class="bi bi-x-lg"></i> Cancel
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center py-4">
                                <i class="bi bi-calendar-x fs-1 text-muted mb-3 d-block"></i>
                                <p class="text-muted mb-0">No appointments scheduled for today</p>
                            </div>
                        }
                    </div>
                </div>

                <!-- Upcoming Appointments -->
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h5 class="fw-bold mb-0">
                                <i class="bi bi-calendar-event text-primary"></i>
                                Upcoming Appointments
                            </h5>
                            <a asp-controller="Provider" asp-action="MyAppointments" class="text-primary text-decoration-none">
                                View All <i class="bi bi-arrow-right"></i>
                            </a>
                        </div>

                        @if (Model.UpcomingAppointments.Any())
                        {
                            foreach (var appointment in Model.UpcomingAppointments.Take(3))
                            {
                                <div class="appointment-card mb-3 p-3 bg-light rounded">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <h6 class="fw-bold mb-1">@appointment.Service.Name</h6>
                                            <p class="text-muted small mb-1">
                                                <i class="bi bi-calendar3"></i> @appointment.AppointmentDate.ToString("MMM dd, yyyy")
                                            </p>
                                            <p class="text-muted small mb-0">
                                                <i class="bi bi-clock"></i> @String.Format("{0:hh\\:mm tt}", DateTime.Today.Add(appointment.StartTime)) - @String.Format("{0:hh\\:mm tt}", DateTime.Today.Add(appointment.EndTime))
                                            </p>
                                        </div>
                                        <span class="badge bg-primary">@appointment.Status</span>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <p class="text-muted text-center mb-0">No upcoming appointments</p>
                        }
                    </div>
                </div>
            </div>

            <!-- Sidebar -->
            <div class="col-lg-4">
                <!-- Profile Card -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body p-4 text-center">
                        <img src="@Model.Provider.ProfileImageUrl"
                             class="rounded-circle mb-3"
                             style="width: 100px; height: 100px; object-fit: cover;"
                             alt="@Model.Provider.FullName">
                        <h5 class="fw-bold mb-1">@Model.Provider.FullName</h5>
                        <p class="text-muted mb-3">@Model.Provider.Specialization</p>

                        <div class="mb-3">
                            <i class="bi bi-star-fill text-warning"></i>
                            <span class="fw-bold">@Model.AverageRating</span>
                            <span class="text-muted">(@Model.TotalReviews reviews)</span>
                        </div>

                        <div class="d-grid gap-2">
                            <a asp-controller="Provider" asp-action="Details" asp-route-id="@Model.Provider.ProviderId"
                               class="btn btn-outline-primary">
                                <i class="bi bi-eye"></i> View Public Profile
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Quick Actions -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body p-4">
                        <h6 class="fw-bold mb-3">Quick Actions</h6>
                        <div class="d-grid gap-2">
                            <a asp-controller="Provider" asp-action="Schedule" class="btn btn-outline-primary">
                                <i class="bi bi-calendar-range"></i> Manage Schedule
                            </a>
                            <a asp-controller="Provider" asp-action="MyAppointments" class="btn btn-outline-primary">
                                <i class="bi bi-list-check"></i> All Appointments
                            </a>
                            <button class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#settingsModal">
                                <i class="bi bi-gear"></i> Settings
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Performance -->
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <h6 class="fw-bold mb-3">This Month Performance</h6>
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="small">Completed</span>
                                <span class="small fw-bold">@Model.MonthAppointmentsCount</span>
                            </div>
                            <div class="progress" style="height: 8px;">
                                <div class="progress-bar bg-success" style="width: 75%"></div>
                            </div>
                        </div>
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="small">Revenue</span>
                                <span class="small fw-bold">$@Model.MonthRevenue</span>
                            </div>
                            <div class="progress" style="height: 8px;">
                                <div class="progress-bar bg-primary" style="width: 60%"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        function completeAppointment(id) {
            if (confirm('Mark this appointment as completed?')) {
                $.post('/Provider/UpdateAppointmentStatus', { id: id, status: 'Completed' }, function () {
                    showToast('Appointment marked as completed', 'success');
                    setTimeout(() => location.reload(), 1000);
                });
            }
        }

        function cancelAppointment(id) {
            if (confirm('Are you sure you want to cancel this appointment?')) {
                $.post('/Provider/UpdateAppointmentStatus', { id: id, status: 'Cancelled' }, function () {
                    showToast('Appointment cancelled', 'warning');
                    setTimeout(() => location.reload(), 1000);
                });
            }
        }

        $('#toggleAvailability').on('click', function () {
            const isAvailable = $(this).text().includes('Set Unavailable');
            $.post('/Provider/UpdateAvailability', { isAvailable: !isAvailable }, function () {
                showToast('Availability updated', 'success');
                setTimeout(() => location.reload(), 1000);
            });
        });
    </script>
}