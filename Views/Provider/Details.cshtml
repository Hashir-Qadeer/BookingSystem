@{
}
@model BookingSystem.ViewModels.ProviderDetailsViewModel

@{
    ViewData["Title"] = Model.Provider.FullName + " - Profile";
}

<section class="py-5 bg-light">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm text-center p-4">
                    <img src="@Model.Provider.ProfileImageUrl" class="rounded-circle mx-auto mb-3 border border-4 border-white shadow-sm" style="width: 150px; height: 150px; object-fit: cover;">
                    <h3 class="fw-bold">@Model.Provider.FullName</h3>
                    <p class="text-primary fw-semibold">@Model.Provider.Specialization</p>
                    <div class="d-flex justify-content-center gap-2 mb-3">
                        <span class="badge bg-warning text-dark"><i class="bi bi-star-fill"></i> @Model.Provider.Rating</span>
                        <span class="text-muted">(@Model.TotalReviews Reviews)</span>
                    </div>
                    <p class="text-muted small">@Model.Provider.Bio</p>
                    <hr>
                    <div class="text-start">
                        <p class="small mb-1"><strong>Experience:</strong> @Model.Provider.YearsOfExperience Years</p>
                        <p class="small mb-0">
                            <strong>Status:</strong>
                            <span class="text-@(Model.Provider.IsAvailable ? "success" : "danger")">
                                <i class="bi bi-circle-fill small"></i> @(Model.Provider.IsAvailable ? "Available" : "Busy")
                            </span>
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-lg-8">
                <div class="card border-0 shadow-sm p-4 mb-4">
                    <h4 class="fw-bold mb-4">Services Offered</h4>
                    <div class="row g-3">
                        @foreach (var service in Model.Services)
                        {
                            <div class="col-md-6">
                                <div class="p-3 border rounded d-flex justify-content-between align-items-center">
                                    <div>
                                        <h6 class="fw-bold mb-0">@service.Name</h6>
                                        <small class="text-muted">@service.DurationMinutes min · $@service.Price</small>
                                    </div>
                                    <a asp-controller="Booking" asp-action="Book"
                                       asp-route-serviceId="@service.ServiceId"
                                       asp-route-providerId="@Model.Provider.ProviderId"
                                       class="btn btn-sm btn-primary">Book Now</a>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="card border-0 shadow-sm p-4">
                    <h4 class="fw-bold mb-4">Reviews & Ratings</h4>
                    @foreach (var rate in Model.RatingDistribution.OrderByDescending(x => x.Key))
                    {
                        var percent = Model.TotalReviews > 0 ? (rate.Value * 100 / Model.TotalReviews) : 0;
                        <div class="d-flex align-items-center mb-2">
                            <span class="small me-2" style="width: 30px;">@rate.Key <i class="bi bi-star-fill text-warning"></i></span>
                            <div class="progress flex-grow-1" style="height: 8px;">
                                <div class="progress-bar bg-warning" style="width: @percent%"></div>
                            </div>
                            <span class="small ms-2 text-muted">@rate.Value</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>