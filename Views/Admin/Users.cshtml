@{
}
@model BookingSystem.ViewModels.AdminUsersViewModel

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold">User Management</h3>
        <span class="badge bg-dark">Total: @Model.TotalUsers</span>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>User</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="avatar-sm bg-primary-subtle text-primary rounded-circle p-2 me-2">
                                        <i class="bi bi-person"></i>
                                    </div>
                                    <div class="fw-bold">@user.FirstName @user.LastName</div>
                                </div>
                            </td>
                            <td>@user.Email</td>
                            <td>
                                <span class="badge bg-@(user.Role == "Admin" ? "danger" : user.Role == "Provider" ? "info" : "secondary")">
                                    @user.Role
                                </span>
                            </td>
                            <td>
                                <span class="text-@(user.IsActive ? "success" : "danger") fw-bold">
                                    @(user.IsActive ? "● Active" : "● Inactive")
                                </span>
                            </td>
                            <td class="text-end">
                                <button onclick="deactivateUser('@user.UserId')" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-slash-circle"></i> Deactivate
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function deactivateUser(id) {
            if (confirm('Are you sure you want to deactivate this user?')) {
                $.post('/Admin/DeactivateUser', { id: id }, function () {
                    location.reload();
                });
            }
        }
    </script>
}