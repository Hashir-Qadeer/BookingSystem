@model BookingSystem.ViewModels.AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
}

<section class="py-4 bg-dark text-white">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h2 class="fw-bold mb-2">
                    <i class="bi bi-shield-lock"></i> Admin Dashboard
                </h2>
                <p class="mb-0">System Overview & Management</p>
            </div>
            <div class="col-md-4 text-md-end">
                <span class="badge bg-light text-dark">
                    <i class="bi bi-calendar3"></i> @DateTime.Today.ToString("MMM dd, yyyy")
                </span>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-light">
    <div class="container">
        <!-- Main Stats -->
        <div class="row g-4 mb-5">
            <div class="col-lg-3 col-md-6">
                <div class="card border-0 shadow-sm h-100 stat-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <p class="text-muted mb-1">Total Users</p>
                                <h3 class="fw-bold mb-0">@Model.TotalUsers</h3>
                                <small class="text-success">
                                    <i class="bi bi-arrow-up"></i> All active
                                </small>
                            </div>
                            <div class="stat-icon bg-primary-subtle">
                                <i class="bi bi-people fs-1 text-primary"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-6">
                <div class="card border-0 shadow-sm h-100 stat-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <p class="text-muted mb-1">Total Providers</p>
                                <h3 class="fw-bold mb-0">@Model.TotalProviders</h3>
                                <small class="text-info">
                                    <i class="bi bi-check-circle"></i> Verified
                                </small>
                            </div>
                            <div class="stat-icon bg-success-subtle">
                                <i class="bi bi-person-badge fs-1 text-success"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-6">
                <div class="card border-0 shadow-sm h-100 stat-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <p class="text-muted mb-1">Total Appointments</p>
                                <h3 class="fw-bold mb-0">@Model.TotalAppointments</h3>
                                <small class="text-warning">
                                    <i class="bi bi-clock"></i> @Model.PendingAppointments pending
                                </small>
                            </div>
                            <div class="stat-icon bg-warning-subtle">
                                <i class="bi bi-calendar-check fs-1 text-warning"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-6">
                <div class="card border-0 shadow-sm h-100 stat-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <p class="text-muted mb-1">Total Revenue</p>
                                <h3 class="fw-bold mb-0">$@Model.TotalRevenue.ToString("0.00")</h3>
                                <small class="text-success">
                                    <i class="bi bi-graph-up"></i> $@Model.MonthRevenue this month
                                </small>
                            </div>
                            <div class="stat-icon bg-info-subtle">
                                <i class="bi bi-currency-dollar fs-1 text-info"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Stats Row -->
        <div class="row g-4 mb-5">
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <h6 class="fw-bold mb-3">Today's Overview</h6>
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span>Appointments Today</span>
                            <span class="badge bg-primary">@Model.TodayAppointments</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span>Active Providers</span>
                            <span class="badge bg-success">@Model.TotalProviders</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span>Active Services</span>
                            <span class="badge bg-info">@Model.TotalServices</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <h6 class="fw-bold mb-3">Appointments by Status</h6>
                        @foreach (var status in Model.AppointmentsByStatus)
                        {
                            <div class="mb-2">
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="small">@status.Key</span>
                                    <span class="small fw-bold">@status.Value</span>
                                </div>
                                <div class="progress" style="height: 6px;">
                                    <div class="progress-bar @GetStatusColor(status.Key)"
                                         style="width: @((status.Value * 100.0 / Model.TotalAppointments))%"></div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <h6 class="fw-bold mb-3">Quick Actions</h6>
                        <div class="d-grid gap-2">
                            <a asp-controller="Admin" asp-action="Services" class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-list-check"></i> Manage Services
                            </a>
                            <a asp-controller="Admin" asp-action="Providers" class="btn btn-outline-success btn-sm">
                                <i class="bi bi-person-badge"></i> Manage Providers
                            </a>
                            <a asp-controller="Admin" asp-action="Users" class="btn btn-outline-info btn-sm">
                                <i class="bi bi-people"></i> Manage Users
                            </a>
                            <a asp-controller="Admin" asp-action="Analytics" class="btn btn-outline-warning btn-sm">
                                <i class="bi bi-graph-up"></i> View Analytics
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <!-- Recent Appointments -->
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h5 class="fw-bold mb-0">
                                <i class="bi bi-clock-history text-primary"></i>
                                Recent Appointments
                            </h5>
                            <a asp-controller="Admin" asp-action="Appointments" class="text-primary text-decoration-none">
                                View All <i class="bi bi-arrow-right"></i>
                            </a>
                        </div>

                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Service</th>
                                        <th>Provider</th>
                                        <th>Date</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var appointment in Model.RecentAppointments)
                                    {
                                        <tr>
                                            <td>#@appointment.AppointmentId</td>
                                            <td>@appointment.Service.Name</td>
                                            <td>@appointment.Provider.FullName</td>
                                            <td>@appointment.AppointmentDate.ToString("MMM dd")</td>
                                            <td>
                                                <span class="badge @GetStatusBadge(appointment.Status)">
                                                    @appointment.Status
                                                </span>
                                            </td>
                                            <td>
                                                <button class="btn btn-sm btn-outline-primary" title="View">
                                                    <i class="bi bi-eye"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Top Providers -->
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4">
                            <i class="bi bi-star-fill text-warning"></i>
                            Top Providers
                        </h5>

                        @foreach (var provider in Model.TopProviders)
                        {
                            <div class="d-flex align-items-center mb-3 pb-3 border-bottom">
                                <img src="@provider.ProfileImageUrl"
                                     class="rounded-circle me-3"
                                     style="width: 50px; height: 50px; object-fit: cover;"
                                     alt="@provider.FullName">
                                <div class="flex-grow-1">
                                    <h6 class="mb-0">@provider.FullName</h6>
                                    <small class="text-muted">@provider.Specialization</small>
                                    <div>
                                        <i class="bi bi-star-fill text-warning small"></i>
                                        <span class="small fw-bold">@provider.Rating</span>
                                        <span class="small text-muted">(@provider.TotalReviews)</span>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@functions {
    string GetStatusColor(string status)
    {
        return status switch
        {
            "Confirmed" => "bg-success",
            "Pending" => "bg-warning",
            "Completed" => "bg-primary",
            "Cancelled" => "bg-danger",
            _ => "bg-secondary"
        };
    }

    string GetStatusBadge(string status)
    {
        return status switch
        {
            "Confirmed" => "bg-success",
            "Pending" => "bg-warning",
            "Completed" => "bg-primary",
            "Cancelled" => "bg-danger",
            _ => "bg-secondary"
        };
    }
}

@section Scripts {
    <script>
        // Animate stat cards
        $('.stat-card').each(function (i) {
            $(this).css({
                'opacity': '0',
                'transform': 'translateY(20px)'
            }).delay(i * 100).animate({
                'opacity': '1'
            }, 500, function () {
                $(this).css('transform', 'translateY(0)');
            });
        });
    </script>
}@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
