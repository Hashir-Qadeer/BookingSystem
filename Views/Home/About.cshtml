@{
    ViewData["Title"] = "About Us";
}

<section class="hero-section-small bg-primary text-white py-5">
    <div class="container text-center">
        <h1 class="display-4 fw-bold mb-3">About BookingSystem</h1>
        <p class="lead">Your trusted platform for seamless appointment booking</p>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row align-items-center mb-5">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <img src="https://images.unsplash.com/photo-1556761175-b413da4baf72?w=600"
                     class="img-fluid rounded-4 shadow-lg"
                     alt="About Us">
            </div>
            <div class="col-lg-6">
                <h2 class="fw-bold mb-4">Our Mission</h2>
                <p class="text-muted mb-3">
                    At BookingSystem, we're revolutionizing the way people book and manage appointments with service providers.
                    Our platform connects customers with top-rated professionals across various industries, making the booking
                    process simple, fast, and reliable.
                </p>
                <p class="text-muted mb-4">
                    Whether you're looking for healthcare services, beauty treatments, wellness sessions, or fitness training,
                    we've got you covered. Our mission is to save you time and provide peace of mind with instant confirmations,
                    easy rescheduling, and transparent pricing.
                </p>
                <div class="row g-3">
                    <div class="col-6">
                        <div class="stat-box text-center p-3 bg-light rounded">
                            <h3 class="fw-bold text-primary mb-0">48+</h3>
                            <p class="text-muted small mb-0">Service Providers</p>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="stat-box text-center p-3 bg-light rounded">
                            <h3 class="fw-bold text-primary mb-0">1250+</h3>
                            <p class="text-muted small mb-0">Happy Customers</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-light">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold mb-3">Why Choose Us?</h2>
            <p class="text-muted">Here's what makes BookingSystem the best choice for your appointments</p>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="feature-card card border-0 shadow-sm h-100 text-center p-4">
                    <div class="feature-icon mb-3">
                        <i class="bi bi-shield-check text-primary fs-1"></i>
                    </div>
                    <h5 class="fw-bold mb-3">Verified Professionals</h5>
                    <p class="text-muted mb-0">
                        All our service providers are carefully vetted and verified to ensure you receive
                        the highest quality service every time.
                    </p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card card border-0 shadow-sm h-100 text-center p-4">
                    <div class="feature-icon mb-3">
                        <i class="bi bi-lightning-charge text-warning fs-1"></i>
                    </div>
                    <h5 class="fw-bold mb-3">Instant Booking</h5>
                    <p class="text-muted mb-0">
                        Book appointments in seconds with real-time availability. Get instant confirmation
                        and reminders for your upcoming appointments.
                    </p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card card border-0 shadow-sm h-100 text-center p-4">
                    <div class="feature-icon mb-3">
                        <i class="bi bi-calendar-check text-success fs-1"></i>
                    </div>
                    <h5 class="fw-bold mb-3">Flexible Scheduling</h5>
                    <p class="text-muted mb-0">
                        Easily reschedule or cancel appointments up to 24 hours in advance.
                        We make managing your bookings hassle-free.
                    </p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card card border-0 shadow-sm h-100 text-center p-4">
                    <div class="feature-icon mb-3">
                        <i class="bi bi-star-fill text-warning fs-1"></i>
                    </div>
                    <h5 class="fw-bold mb-3">Verified Reviews</h5>
                    <p class="text-muted mb-0">
                        Read authentic reviews from real customers to make informed decisions
                        about your service provider selection.
                    </p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card card border-0 shadow-sm h-100 text-center p-4">
                    <div class="feature-icon mb-3">
                        <i class="bi bi-headset text-info fs-1"></i>
                    </div>
                    <h5 class="fw-bold mb-3">24/7 Support</h5>
                    <p class="text-muted mb-0">
                        Our dedicated customer support team is available around the clock to
                        assist you with any questions or concerns.
                    </p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card card border-0 shadow-sm h-100 text-center p-4">
                    <div class="feature-icon mb-3">
                        <i class="bi bi-phone text-primary fs-1"></i>
                    </div>
                    <h5 class="fw-bold mb-3">Mobile Friendly</h5>
                    <p class="text-muted mb-0">
                        Book on the go with our fully responsive platform. Access your appointments
                        from any device, anywhere, anytime.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 order-lg-2 mb-4 mb-lg-0">
                <img src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=600"
                     class="img-fluid rounded-4 shadow-lg"
                     alt="Our Team">
            </div>
            <div class="col-lg-6 order-lg-1">
                <h2 class="fw-bold mb-4">Our Story</h2>
                <p class="text-muted mb-3">
                    Founded in 2024, BookingSystem was born from a simple idea: booking appointments
                    shouldn't be complicated. Our founders experienced firsthand the frustration of
                    endless phone calls, waiting times, and scheduling conflicts.
                </p>
                <p class="text-muted mb-3">
                    We set out to create a platform that would streamline the entire process, making
                    it easy for customers to find, book, and manage appointments with trusted service
                    providers. Today, we're proud to serve thousands of customers and support hundreds
                    of businesses across multiple industries.
                </p>
                <p class="text-muted mb-4">
                    Our commitment to excellence, innovation, and customer satisfaction drives
                    everything we do. We're constantly improving our platform to provide the best
                    possible experience for both customers and service providers.
                </p>
                <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-lg">
                    Join Us Today <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-primary text-white">
    <div class="container text-center">
        <h2 class="fw-bold mb-3">Ready to Get Started?</h2>
        <p class="lead mb-4">Join thousands of satisfied customers who trust BookingSystem</p>
        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <a asp-controller="Services" asp-action="Index" class="btn btn-light btn-lg px-5">
                Browse Services
            </a>
            <a asp-controller="Home" asp-action="Contact" class="btn btn-outline-light btn-lg px-5">
                Contact Us
            </a>
        </div>
    </div>
</section>